{
  "name": "table-minimap",
  "version": "2.0.0",
  "description": "Tired of explaining to your boss why having too many columns in a table isn't a good idea? Give him Table-Minimap so he'll leave you alone.",
  "type": "module",
  "main": "./dist/table-minimap.cjs",
  "module": "./dist/table-minimap.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/table-minimap.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/table-minimap.cjs"
      }
    },
    "./style.css": "./dist/style.css",
    "./shadcn.css": "./dist/shadcn.css"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp src/shadcn.css dist/shadcn.css",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "npm run test:unit && npm run test:e2e",
    "test:ci": "npm run lint && npm run build && npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build",
    "deploy": "npm run build:demo && gh-pages -d demo-dist"
  },
  "keywords": [
    "table",
    "minimap",
    "scroll",
    "navigation",
    "typescript",
    "vanilla-js",
    "no-dependencies",
    "shadcn",
    "shadcn-ui",
    "react",
    "tailwind"
  ],
  "author": "Kevin Imig aka kevincii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kevinci/table-minimap.git"
  },
  "homepage": "https://kevinci.github.io/table-minimap/",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.61.0",
    "eslint": "^9.30.1",
    "gh-pages": "^6.3.0",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.35.1",
    "vite": "^8.0.5",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^4.1.9"
  }
}
