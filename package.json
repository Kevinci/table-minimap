{
  "name": "table-minimap",
  "version": "1.0.5",
  "description": "Tired of explaining to your boss why having too many columns in a table isn't a good idea? Give him Table-Minimap so he'll leave you alone.",
  "type": "module",
  "main": "./dist/table-minimap.cjs",
  "module": "./dist/table-minimap.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/table-minimap.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/table-minimap.cjs"
      }
    },
    "./style.css": "./dist/style.css",
    "./shadcn.css": "./dist/shadcn.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp src/shadcn.css dist/shadcn.css",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "deploy": "npm run build:demo && gh-pages -d demo-dist"
  },
  "keywords": [
    "table",
    "minimap",
    "scroll",
    "navigation",
    "typescript",
    "vanilla-js",
    "no-dependencies",
    "shadcn",
    "shadcn-ui",
    "react",
    "tailwind"
  ],
  "author": "Kevin Imig aka kevincii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kevinci/table-minimap.git"
  },
  "homepage": "https://kevinci.github.io/table-minimap/",
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1"
  }
}
